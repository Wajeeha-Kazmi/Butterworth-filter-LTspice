import math

pi = 3.141592653589793
Q = [0.555, 0.801, 2.247]

selectedQ = Q[0]  # Change the index as needed (0, 1, or 2)

C2 = 1e-9
C4 = C2 / (4 * selectedQ * selectedQ)

w0 = 15.54e3 * 2 * pi

R_ohms = 1 / (w0 * math.sqrt(C2 * C4))
R_ord1_ohms = 1 / (w0 * 100e-12)

# Convert ohms to kiloohms by multiplying by 1e-3 (same as dividing by 1000)
R_kohms = R_ohms * 1e-3
R_ord1_kohms = R_ord1_ohms * 1e-3

print("Selected Q:", selectedQ)
print(f"C2 = {C2:.2e} F")
print(f"C4 = {C4:.2e} F")
print(f"R = {R_kohms:.2e} kΩ")
print(f"R order 1 = {R_ord1_kohms:.2e} kΩ")
